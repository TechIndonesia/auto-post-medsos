# Salin file ini menjadi .env lalu isi nilainya.
# Di Vercel: tambahkan variabel-variabel ini di Settings -> Environment Variables.

# PostgreSQL (wajib). Contoh: Neon, Supabase, atau Vercel Postgres.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Arena AI API key (untuk generate teks/foto/video). Ambil di https://arena.ai -> Keys
ARENA_API_KEY=

# Base URL Arena API (opsional, default sudah benar)
ARENA_BASE_URL=https://api.preview.arena.ai

# Opsional: lindungi endpoint cron dengan secret
CRON_SECRET=
